# Runtime
AGENT_ENVIRONMENT=development
AGENT_DEBUG=true

# PostgreSQL / PGVector
AGENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent
AGENT_TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_test
AGENT_PGVECTOR_COLLECTION=agent_vectors
AGENT_PGVECTOR_TABLE=agent_vector_items
AGENT_TASK_TABLE=agent_tasks

# OpenAI-compatible proxy endpoint
# Example: https://your-proxy.example.com/v1
AGENT_OPENAI_BASE_URL=https://your-openai-proxy.example.com/v1
AGENT_OPENAI_API_KEY=replace-with-your-proxy-api-key
AGENT_LLM_MODEL_NAME=gpt-4o-mini
AGENT_EMBEDDING_MODEL_NAME=text-embedding-3-small
AGENT_EMBEDDING_DIMENSION=384

# Indexing / retrieval
AGENT_DOCS_PATH=docs
AGENT_CODE_INDEX_PATH=app
AGENT_RETRIEVAL_TOP_K=5
AGENT_RETRIEVAL_SCORE_THRESHOLD=0.0
AGENT_CHUNK_SIZE=1000
AGENT_CHUNK_OVERLAP=120
